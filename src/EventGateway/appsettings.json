{
  "ConnectionStrings": {
    "EventLedgerDb": "Data Source=EventGateway;Mode=Memory;Cache=Shared"
  },
  "AccountService": {
    "BaseUrl": "http://localhost:5001"
  },
  "ApiKeyAuth": {
    "Enabled": false,
    "HeaderName": "X-Api-Key",
    "ApiKey": "demo-gateway-key-change-me"
  },
  "InternalAuth": {
    "Enabled": false,
    "HeaderName": "X-Internal-Token",
    "Token": "demo-internal-token-change-me"
  },
  "RateLimiting": {
    "Enabled": false,
    "PermitLimit": 100,
    "WindowSeconds": 1
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
